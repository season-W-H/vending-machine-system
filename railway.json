{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKER",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "gunicorn vending_machine.wsgi:application --bind 0.0.0.0:$PORT --workers 2 --threads 4",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30
  }
}
